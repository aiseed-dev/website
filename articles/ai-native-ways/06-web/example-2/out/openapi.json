          },
          "item": {
            "type": "string",
            "title": "Item"
          },
          "qty": {
            "type": "integer",
            "title": "Qty"
          },
          "unit_price": {
            "type": "integer",
            "title": "Unit Price"
          },
          "total": {
            "type": "integer",
