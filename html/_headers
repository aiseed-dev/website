# Cloudflare Pages HTTP response headers
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Security headers applied to every response. The Content-Security-Policy
# is still emitted via <meta http-equiv> in each HTML page (see
# tools/templates/) — these headers cover the items that cannot be set
# via meta and the modern security baseline.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), accelerometer=(), gyroscope=(), magnetometer=(), payment=(), usb=(), midi=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site

# Cache vendored Mermaid bundle aggressively — pinned by version in the
# filename, so the URL changes when the version changes.
/js/vendor/*
  Cache-Control: public, max-age=31536000, immutable
